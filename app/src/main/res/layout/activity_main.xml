<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--    như đ xem preview thôi-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/viewInfo"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_margin="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp">

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/app_name"
                android:scaleType="centerCrop"
                android:src="@drawable/img_backgroud" />

        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/batteryBody"
            android:layout_width="48dp"
            android:layout_height="22dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/battery_outline"
            android:padding="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/batteryProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:progress="80"
                android:progressDrawable="@drawable/battery_progress" />

            <ImageView
                android:id="@+id/imgCharging"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lightning"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <View
            android:id="@+id/batteryCap"
            android:layout_width="4dp"
            android:layout_height="10dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/battery_cap"
            app:layout_constraintBottom_toBottomOf="@id/batteryBody"
            app:layout_constraintStart_toEndOf="@id/batteryBody"
            app:layout_constraintTop_toTopOf="@id/batteryBody" />

        <TextClock
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:format12Hour="hh:mm"
            android:format24Hour="HH:mm"
            android:shadowColor="#66000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:textColor="@color/color_black"
            android:textSize="46sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextClock
            android:id="@+id/tvWeekDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:shadowColor="#66000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:textColor="@color/color_black"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/tvMonthDay"
            app:layout_constraintStart_toStartOf="parent" />

        <TextClock
            android:id="@+id/tvMonthDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="14dp"
            android:format12Hour="MMMM d"
            android:format24Hour="MMMM d"
            android:shadowColor="#66000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:textColor="@color/color_black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/groupInfoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="tvTime,tvWeekDay,tvMonthDay" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--    anime girl-->
    <ImageView
        android:id="@+id/imgAnimeGirl"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="44dp"
        android:src="@drawable/img_anime_girl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.051"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/viewInfo" />

    <!--    con mèo nhỏ -->
    <!-- Ảnh -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/widgetCat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/imgAnimeGirl"
        app:layout_constraintTop_toBottomOf="@id/viewInfo">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgCat"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="44dp"
            android:elevation="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_cat_2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/Rounded40"

            app:strokeColor="@color/colorAccent"
            app:strokeWidth="2dp" />

        <!-- Khung PNG -->
        <ImageView
            android:id="@+id/imgCatFrame"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:clickable="false"
            android:focusable="false"
            android:src="@drawable/img_bg"
            app:layout_constraintBottom_toBottomOf="@id/imgCat"
            app:layout_constraintEnd_toEndOf="@id/imgCat"
            app:layout_constraintStart_toStartOf="@id/imgCat"
            app:layout_constraintTop_toTopOf="@id/imgCat" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/imgAnimated"
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:scaleType="fitStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgAnimeGirl"
        tools:src="@drawable/img_anime_girl" />
    <!---->

    <!--    <ImageView-->
    <!--        android:id="@+id/imgAnimatedReview"-->
    <!--        android:layout_width="wrap_content"-->
    <!--        android:layout_height="100dp"-->
    <!--        android:scaleType="fitStart"-->
    <!--        app:layout_constraintEnd_toEndOf="parent"-->
    <!--        app:layout_constraintTop_toBottomOf="@id/imgAnimated"-->
    <!--        tools:src="@drawable/img_anime_girl" />-->


    <ImageView
        android:id="@+id/imgSchedule"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgAnimated"
        android:src="@drawable/img_cat_1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="7h sáng đổi ảnh"
        app:layout_constraintStart_toEndOf="@id/imgSchedule"
        app:layout_constraintTop_toBottomOf="@id/imgAnimated" />

    <!--ViewFlipper -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imgVFContainer"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgAnimeGirl"
        app:strokeColor="#00B1FF"
        app:strokeWidth="2dp">

        <ViewFlipper
            android:id="@+id/imgVF"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:autoStart="true"
            android:flipInterval="700"
            android:inAnimation="@android:anim/fade_in"
            android:outAnimation="@android:anim/fade_out">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_cat_1" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_cat_2" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_cat_3" />
        </ViewFlipper>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/cardStackView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="#111111"
        android:gravity="center"
        android:elevation="2dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stack View"
            android:textColor="#ffff" />

        <ViewFlipper
            android:id="@+id/previewFlipper"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:autoStart="true"
            android:outAnimation="@anim/bottom_slide"
            android:inAnimation="@anim/up_slide"
            android:flipInterval="700">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_cat_1" />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_cat_2" />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_cat_3" />
        </ViewFlipper>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
